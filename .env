PORT=3000

# GitHub API
# Optional but strongly recommended to avoid rate limiting.
# Create a token at: https://github.com/settings/tokens
# A token with no scopes (public access only) is sufficient.

GITHUB_TOKEN=

# Scoring Weights
# Must sum to 1.0. Adjust to change which factor matters most.
SCORE_WEIGHT_STARS=0.5
SCORE_WEIGHT_FORKS=0.3
SCORE_WEIGHT_RECENCY=0.2

# Recency half-life in days.
# A repo last pushed this many days ago will receive a recency score of 50/100.
SCORE_RECENCY_HALF_LIFE_DAYS=365

# Reference values for normalisation
REF_STARS = 200_000; 

# Reference fork count for normalisation
REF_FORKS = 10_000;
